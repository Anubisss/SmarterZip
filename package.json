{
  "name": "smarterzip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "scheduler:dev": "nodemon --watch src/scheduler --watch src/lib --exec \"tsx --tsconfig tsconfig.scheduler.json --env-file=.env\" src/scheduler/index.ts",
    "scheduler:prod": "node dist/scheduler/scheduler/index.js",
    "scheduler:build": "tsc -p tsconfig.scheduler.json",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:dockerfiles": "docker run --rm -i hadolint/hadolint hadolint --failure-threshold warning - < src/app/Dockerfile && docker run --rm -i hadolint/hadolint hadolint --failure-threshold warning - < src/scheduler/Dockerfile",
    "type-check": "tsc --noEmit && tsc -p tsconfig.scheduler.json --noEmit",
    "check-all": "rm -rf .next && npm run lint && npm run type-check && npm run prettier && npm run build && npm run scheduler:build && npm audit --audit-level=high && npm run test && npm run lint:dockerfiles",
    "prepare": "husky || true",
    "prettier": "prettier --check .",
    "test": "TZ=UTC jest",
    "test:watch": "TZ=UTC jest --watch"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "axios": "^1.16.1",
    "axios-cookiejar-support": "^5.0.5",
    "better-sqlite3": "^11.10.0",
    "dayjs": "^1.11.20",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "tough-cookie": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.6",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tough-cookie": "^4.0.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.14",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
